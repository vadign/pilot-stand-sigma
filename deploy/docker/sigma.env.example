# Runtime mode for the UI.
VITE_SOURCE_MODE=hybrid

# Server-side scheduler still writes snapshots, but UI always tries live runtime fetch first.
# If source is unavailable, it automatically falls back to snapshot/cache.
VITE_ENABLE_RUNTIME_LIVE_FETCH=true

# Internal app port inside the container.
SIGMA_PORT=4173

# Snapshot refresh period: 3600000 ms = 1 hour.
SIGMA_SNAPSHOT_SYNC_INTERVAL_MS=3600000

# Official reserve source for 051 outages.
VITE_051_PORTAL_URL=https://map.novo-sibirsk.ru/portal/disconnections?t=

# Optional transport/open data settings.
VITE_OPENDATA_BASE_URL=https://opendata.novo-sibirsk.ru
VITE_OPENDATA_PROXY_URL=

# Optional map key.
VITE_YANDEX_MAPS_API_KEY=
